{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(*taskkill*/IM node*)",
      "Bash(*taskkill*//IM node*)",
      "Bash(*taskkill*/IM electron*)",
      "Bash(*taskkill*//IM electron*)",
      "Bash(*taskkill*/IM npm*)",
      "Bash(*taskkill*//IM npm*)",
      "Bash(*taskkill*/IM python*)",
      "Bash(*taskkill*//IM python*)",
      "Bash(*taskkill*/IM claude*)",
      "Bash(*taskkill*//IM claude*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*:*)",
      "Bash(git rm*CLAUDE.md*)",
      "Bash(git rm*CRITICAL-RULES.md*)",
      "Bash(rm*CLAUDE.md*)",
      "Bash(rm*CRITICAL-RULES.md*)"
    ],
    "ask": [
      "Bash(taskkill:*)",
      "Bash(mv *:*)",
      "Bash(rm -rf:*)",
      "Bash(git add *.env:*)",
      "Bash(git commit *.env:*)",
      "Write(.claude/agents/**)",
      "Write(CLAUDE.md)",
      "Write(CRITICAL-RULES.md)",
      "Edit(CLAUDE.md)",
      "Edit(CRITICAL-RULES.md)"
    ]
  },
  "enabledMcpjsonServers": ["playwright"]
}
